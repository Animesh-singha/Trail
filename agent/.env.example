# Nexus Discovery Agent Configuration

# The URL of your central Nexus Hub (ai-analyzer)
NEXUS_HUB_URL=http://localhost:3001

# The security token (must match the backend's NEXUS_AGENT_TOKEN)
NEXUS_AGENT_TOKEN=nexus_secret_agent_token

# How often to collect and push data (in milliseconds)
COLLECTION_INTERVAL=60000
