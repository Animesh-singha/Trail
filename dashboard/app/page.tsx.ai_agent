'use client';

import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  AlertTriangle, Activity, ShieldAlert, CheckCircle, ServerCrash, Server, X, Maximize2, 
  LayoutDashboard, Server as ServerIcon, Globe, ShieldAlert as AlertIcon, 
  Terminal, Share2, ShieldCheck, Share as ShareIcon, Shield, Eye, EyeOff, LogOut,
  Layout, Cpu, Mic, Search, Languages, Image as ImageIcon, RefreshCw, ArrowRight
} from 'lucide-react';

import ChatWidget from '@/components/ChatWidget';
import LiveLogsViewer from '@/components/LiveLogsViewer';
import UptimeMonitor from '@/components/UptimeMonitor';
import ServerGrid from '@/components/ServerGrid';
import SiteCard from '@/components/SiteCard';
import FleetOverview from '@/components/FleetOverview';
import ErrorStream from '@/components/ErrorStream';
import InfrastructureTopology from '@/components/InfrastructureTopology';
import MetricGraph from '@/components/MetricGraph';
import CommandPalette from '@/components/CommandPalette';
import AlertTimeline from '@/components/AlertTimeline';
import RootCauseTimeline from '@/components/RootCauseTimeline';
import { useNeuralAudio } from '@/hooks/useNeuralAudio';
import Lottie from 'lottie-react';

// [REWIND]: To undo this theme, restore from page.tsx.bak and components_bak/

function InteractiveAuth({ onAuth }: { onAuth: () => void }) {
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false);
  const [status, setStatus] = useState<'idle' | 'checking' | 'error' | 'success'>('idle');
  const [mounted, setMounted] = useState(false);
  const [terminalLines, setTerminalLines] = useState<string[]>([
    'SYSTEM: AI AGENT CORE v1.0.4',
    'STATUS: ENCRYPTED GATEWAY LOADED',
    'PROTOCOL: NEURAL_LINK_ESTABLISHED',
    'AWAITING BIOMETRIC CLEARANCE...'
  ]);

  const { play } = useNeuralAudio();

  useEffect(() => {
    setMounted(true);
    play('boot');
    const fetchHistory = async () => {
      try {
        const res = await fetch('http://localhost:3001/v1/auth/history');
        if (res.ok) {
          const history = await res.json();
          const historyLines = history.reverse().map((log: any) => 
            `> LOG: ${log.username || 'ANONYMOUS'} - ${log.status.toUpperCase()}`
          );
          setTerminalLines(prev => [...prev.slice(0, 4), ...historyLines, ...prev.slice(4)]);
        }
      } catch (err) {
        console.error('Failed to fetch auth history', err);
      }
    };
    fetchHistory();
  }, []);

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (status === 'checking') return;
    
    setStatus('checking');
    setTerminalLines(prev => [...prev, `> SCANNING IDENTITY: ${username || 'ANONYMOUS'}...`]);
    
    setTimeout(async () => {
      try {
        const response = await fetch('http://localhost:3001/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password })
        });

        const data = await response.json();

        if (response.ok && data.success) {
          setTerminalLines(prev => [...prev, `> IDENTITY CONFIRMED: ${username}`, '> ACCESS GRANTED.', '> INITIALIZING NEURAL INTERFACE...']);
          setStatus('success');
          setTimeout(onAuth, 1000);
        } else {
          const errorMsg = data.error || 'INVALID CREDENTIALS';
          setTerminalLines(prev => [...prev, `> ATTEMPT BY: ${username || 'UNKNOWN'}`, `> ACCESS DENIED: ${errorMsg.toUpperCase()}.`]);
          setStatus('error');
          setTimeout(() => setStatus('idle'), 3000);
        }
      } catch (err: any) {
        setTerminalLines(prev => [...prev, `> ERROR: ${err.message || 'GATEWAY UNREACHABLE'}`, '> SYSTEM ABORTED.']);
        setStatus('error');
        setTimeout(() => setStatus('idle'), 3000);
      }
    }, 1500);
  };

  if (!mounted) return null;

  return (
    <div className="fixed inset-0 z-[1000] bg-[#050B18] text-white flex items-center justify-center p-6 overflow-hidden">
      {/* Background Orbs */}
      <motion.div
        className="absolute w-[800px] h-[800px] rounded-full bg-gradient-to-r from-cyan-500/10 to-indigo-500/10 blur-[120px] pointer-events-none"
        animate={{ 
          rotate: 360,
          scale: [1, 1.1, 1],
        }}
        transition={{ repeat: Infinity, duration: 25, ease: "linear" }}
      />
      
      <motion.div 
        initial={{ opacity: 0, scale: 0.95, y: 20 }}
        animate={{ opacity: 1, scale: 1, y: 0 }}
        className="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-0 bg-white/[0.02] border border-white/10 rounded-[40px] shadow-[0_50px_100px_rgba(0,0,0,0.6)] backdrop-blur-3xl overflow-hidden relative z-10"
      >
        {/* Terminal Side (Left) */}
        <div className="p-10 bg-black/40 border-b lg:border-b-0 lg:border-r border-white/5 flex flex-col h-[500px] lg:h-auto">
          <div className="flex items-center gap-3 mb-8">
            <div className="flex gap-1.5">
               <div className="w-2.5 h-2.5 rounded-full bg-rose-500/20"></div>
               <div className="w-2.5 h-2.5 rounded-full bg-amber-500/20"></div>
               <div className="w-2.5 h-2.5 rounded-full bg-cyan-500 shadow-[0_0_10px_#06b6d4]"></div>
            </div>
            <span className="text-[10px] font-black uppercase tracking-[0.4em] text-white/20">Secure Node Beta-7</span>
          </div>

          <div className="flex-1 font-mono text-[11px] text-cyan-400/60 overflow-y-auto space-y-2 pr-4 custom-scrollbar flex flex-col-reverse">
            <div className="flex flex-col gap-2 mt-auto">
              {terminalLines.map((line, i) => (
                <div key={`term-${i}-${line.substring(0, 10)}`} className="flex gap-4">
                  <span className="text-white/10 shrink-0">{mounted ? new Date().toLocaleTimeString([], { hour12: false }) : '--:--:--'}</span>
                  <span className={`${line.includes('DENIED') || line.includes('ERROR') ? 'text-rose-500' : line.includes('GRANTED') || line.includes('CONFIRMED') ? 'text-emerald-400 font-bold' : ''}`}>
                    {line}
                  </span>
                </div>
              ))}
              {status === 'checking' && (
                <div className="flex gap-4 items-center animate-pulse">
                  <span className="text-white/10 shrink-0">{mounted ? new Date().toLocaleTimeString([], { hour12: false }) : '--:--:--'}</span>
                  <span className="text-cyan-400">_ EXECUTING_HANDSHAKE...</span>
                </div>
              )}
            </div>
          </div>

          <div className="mt-8 pt-6 border-t border-white/5 flex justify-between items-center text-[9px] font-black text-white/10 uppercase tracking-[0.2em] italic">
             <span>Protocol v4.2.1-Enforced</span>
             <span>Neural Link Ready</span>
          </div>
        </div>

        {/* Form Side (Right) */}
        <div className="p-10 lg:p-16 flex flex-col justify-center bg-transparent relative">
          {/* Subtle logo bg */}
          <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.02] pointer-events-none">
             <Shield size={300} />
          </div>

          <div className="mb-12 relative z-10">
            <motion.div 
               initial={{ opacity: 0, x: -10 }}
               animate={{ opacity: 1, x: 0 }}
               transition={{ delay: 0.3 }}
               className="inline-block px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-[0_0_15px_rgba(6,182,212,0.1)]"
            >
               Gateway Authorization
            </motion.div>
            <h1 className="text-6xl font-black text-white tracking-tighter leading-none mb-3">
               NEXUS <span className="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-500">AGENT</span>
            </h1>
            <p className="text-white/30 text-[11px] font-black uppercase tracking-[0.3em]">Access Restricted to Level 7 Personnel</p>
          </div>

          <form onSubmit={handleLogin} className="space-y-6 relative z-10">
            <div className="space-y-4">
              <div className="group relative">
                <input
                  type="text"
                  placeholder="IDENTITY_UID"
                  value={username}
                  onChange={(e) => {
                    setUsername(e.target.value);
                    if (status === 'error') setStatus('idle');
                  }}
                  className="w-full bg-white/[0.03] border border-white/5 group-focus-within:border-cyan-500/30 rounded-2xl px-6 py-5 text-sm text-white outline-none transition-all placeholder:text-white/10 font-black tracking-widest"
                  autoFocus
                />
                <div className="absolute right-6 top-1/2 -translate-y-1/2 text-white/10 group-focus-within:text-cyan-500 transition-colors">
                   <Share2 size={18} />
                </div>
              </div>

              <div className="group relative">
                <input
                  type={showPassword ? "text" : "password"}
                  placeholder="ACCESS_TOKEN"
                  value={password}
                  onChange={(e) => {
                    setPassword(e.target.value);
                    if (status === 'error') setStatus('idle');
                  }}
                  className={`w-full bg-white/[0.03] border ${status === 'error' ? 'border-rose-500/50' : 'border-white/5 group-focus-within:border-indigo-500/30'} rounded-2xl px-6 py-5 text-sm text-white outline-none transition-all pr-14 placeholder:text-white/10 font-black tracking-widest`}
                />
                <button
                  type="button"
                  onClick={() => setShowPassword(!showPassword)}
                  className="absolute right-6 top-1/2 -translate-y-1/2 text-white/10 hover:text-white transition-colors"
                >
                  {showPassword ? <EyeOff size={18} /> : <Eye size={18} />}
                </button>
              </div>
            </div>

            <button
              type="submit"
              disabled={status === 'checking' || !username || !password}
              className={`w-full py-6 rounded-2xl transition-all font-black text-[11px] uppercase tracking-[0.4em] flex items-center justify-center gap-3 relative overflow-hidden ${
                status === 'checking' ? 'bg-white/5 text-white/20' : 
                status === 'error' ? 'bg-rose-500 text-white' :
                'bg-gradient-to-r from-cyan-600 to-indigo-600 text-white shadow-[0_15px_30px_rgba(6,182,212,0.3)] hover:shadow-[0_20px_50px_rgba(6,182,212,0.5)] active:scale-[0.98]'
              }`}
            >
              {status === 'checking' ? 'Establishing Tunnel...' : 'Initiate Session'}
              {status === 'idle' && <RefreshCw size={14} className="opacity-40" />}
            </button>
          </form>

          <div className="mt-12 text-center opacity-20 hover:opacity-40 transition-opacity">
             <span className="text-[8px] font-black uppercase tracking-[0.5em]">Nexus Central Intelligence • Matrix v4.0</span>
          </div>
        </div>
      </motion.div>
    </div>
  );
}

function GlassPanel({ children, className, title, icon: Icon }: { children: React.ReactNode, className?: string, title?: string, icon?: any }) {
  return (
    <motion.div 
      initial={{ opacity: 0, y: 10 }}
      animate={{ opacity: 1, y: 0 }}
      className={`relative bg-white/[0.02] border border-white/10 rounded-[28px] backdrop-blur-3xl overflow-hidden group hover:border-white/20 transition-all ${className}`}
    >
      {title && (
        <div className="flex items-center justify-between px-6 py-3 border-b border-white/5 bg-white/[0.01]">
          <div className="flex items-center gap-2.5">
            {Icon && <Icon size={14} className="text-cyan-400" />}
            <span className="text-[9px] font-black uppercase tracking-[0.2em] text-white/40">{title}</span>
          </div>
          <div className="flex gap-1">
             <div className="w-1.5 h-1.5 rounded-full bg-white/5 group-hover:bg-cyan-500/30 transition-colors"></div>
             <div className="w-1.5 h-1.5 rounded-full bg-white/5 group-hover:bg-indigo-500/30 transition-colors"></div>
          </div>
        </div>
      )}
      <div className="p-5 h-full">
        {children}
      </div>
    </motion.div>
  );
}

function CircularProgress({ value, label, sublabel }: { value: number, label: string, sublabel?: string }) {
  const radius = 30;
  const circumference = 2 * Math.PI * radius;
  const offset = circumference - (value / 100) * circumference;

  return (
    <div className="flex flex-col items-center">
      <div className="relative w-16 h-16 flex items-center justify-center">
        <svg className="w-full h-full -rotate-90">
          <circle cx="32" cy="32" r={radius} className="stroke-white/5 fill-none" strokeWidth="4" />
          <motion.circle 
            cx="32" cy="32" r={radius} 
            className="stroke-cyan-500 fill-none" 
            strokeWidth="4" 
            strokeDasharray={circumference}
            initial={{ strokeDashoffset: circumference }}
            animate={{ strokeDashoffset: offset }}
            transition={{ duration: 1.5, ease: "easeOut" }}
          />
        </svg>
        <span className="absolute text-[10px] font-black text-white">{value}%</span>
      </div>
      <span className="text-[9px] font-black text-white/40 uppercase tracking-widest mt-2">{label}</span>
      {sublabel && <span className="text-[8px] text-cyan-500/50 font-bold">{sublabel}</span>}
    </div>
  );
}

export default function DashboardPage() {
  const { play, muted, toggleMute } = useNeuralAudio();
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [incidents, setIncidents] = useState<any[]>([]);
  const [stats, setStats] = useState({ total: 0, critical: 0, last24h: 0 });
  const [narrative, setNarrative] = useState("Neural protocols active. Query authorized for infrastructure analysis.");
  const [loading, setLoading] = useState(true);
  const [monitoredSites, setMonitoredSites] = useState<any[]>([]);
  const [servers, setServers] = useState<any[]>([]);
  const [analytics, setAnalytics] = useState<any>({ mttr: '0.0', frequency: [] });
  const [selectedSite, setSelectedSite] = useState<any | null>(null);
  const [selectedIncident, setSelectedIncident] = useState<any | null>(null);
  const [aiAnalysis, setAiAnalysis] = useState<any | null>(null);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [activeTab, setActiveTab] = useState<'overview' | 'infra' | 'sites' | 'map' | 'errors' | 'incidents'>('overview');
  const [isCommandPaletteOpen, setIsCommandPaletteOpen] = useState(false);
  const [timelineEvents, setTimelineEvents] = useState<any[]>([]);
  const [isTimelineLoading, setIsTimelineLoading] = useState(false);

  const handleExplainAI = async () => {
    if (!selectedIncident) return;
    setIsAnalyzing(true);
    try {
      const res = await fetch(`http://localhost:3001/v1/incidents/${selectedIncident.id}/analyze`);
      if (res.ok) {
        const data = await res.json();
        setAiAnalysis(data);
      }
    } finally {
      setIsAnalyzing(false);
    }
  };

  useEffect(() => {
    if (!selectedIncident) setAiAnalysis(null);
  }, [selectedIncident]);

  useEffect(() => {
    if (selectedIncident) {
      const fetchTimeline = async () => {
        setIsTimelineLoading(true);
        try {
          const res = await fetch(`http://localhost:3001/v1/incidents/${selectedIncident.id}/timeline`);
          if (res.ok) {
            const data = await res.json();
            setTimelineEvents(data);
          }
        } finally {
          setIsTimelineLoading(false);
        }
      };
      fetchTimeline();
    }
  }, [selectedIncident]);

  useEffect(() => {
    const handleGlobalKeyDown = (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        setIsCommandPaletteOpen(prev => !prev);
      }
    };
    window.addEventListener('keydown', handleGlobalKeyDown);
    return () => window.removeEventListener('keydown', handleGlobalKeyDown);
  }, []);

  useEffect(() => {
    const loadData = async () => {
      try {
        const dummyStats = { total: 0, critical: 0, last24h: 0 };
        setStats(dummyStats);
        
        // Fetch incidents from AI Analyzer
        const incRes = await fetch('http://localhost:3001/v1/incidents');
        if (incRes.ok) {
           const incData = await incRes.json();
           setIncidents(incData);
           setStats({
             total: incData.length,
             critical: incData.filter((i: any) => i.severity === 'CRITICAL' && i.status !== 'RESOLVED').length,
             last24h: incData.filter((i: any) => new Date(i.timestamp).getTime() > Date.now() - 86400000).length
           });
        }

        const statsRes = await fetch('http://localhost:3001/v1/incidents/stats');
        if (statsRes.ok) {
           const statsData = await statsRes.json();
           setAnalytics(statsData);
        }

        const res = await fetch('/api/metrics');
        if (res.ok) {
          const data = await res.json();
          if (data.websites) setMonitoredSites(data.websites);
          if (data.servers) setServers(data.servers);
        }
      } finally {
        setLoading(false);
      }
    };
    loadData();
    const interval = setInterval(loadData, 10000);
    return () => clearInterval(interval);
  }, []);

  const handleStatusUpdate = async (id: number, status: string) => {
     try {
        const res = await fetch(`http://localhost:3001/v1/incidents/${id}`, {
           method: 'PATCH',
           headers: { 'Content-Type': 'application/json' },
           body: JSON.stringify({ status })
        });
        if (res.ok) {
           // Refresh UI
           const updated = await res.json();
           setIncidents((prev: any[]) => prev.map((i: any) => i.id === id ? updated : i));
        }
     } catch (err) {
        console.error('Failed to update incident status', err);
     }
  };

  const healthScore = Math.max(0, 100 - (Number(stats.critical) * 10) - (incidents.filter((i: any) => i.status === 'OPEN').length * 2));

  useEffect(() => {
    if (healthScore < 50) {
      setNarrative("CRITICAL: System integrity failing. Neural pathways are compromised. Recommending immediate purge.");
      play('alert');
    } else if (incidents.some((i: any) => i.severity === 'CRITICAL' && i.status === 'OPEN')) {
      setNarrative("WARNING: High-severity threat vector detected in active nodes. Initiating counter-measures.");
      play('alert');
    } else if (healthScore > 90) {
      setNarrative("OPTIMAL: System harmonics are balanced. AI core is operating at peak efficiency.");
    }
  }, [healthScore, incidents.length]);

  // Group sites by VPS
  const sitesByVps = monitoredSites.reduce((acc: Record<string, any[]>, site: any) => {
    const vps = site.vps || 'unknown';
    if (!acc[vps]) acc[vps] = [];
    acc[vps].push(site);
    return acc;
  }, {});

  const tabs = [
    { id: 'overview', label: 'Overview', icon: LayoutDashboard },
    { id: 'infra', label: 'Infrastructure', icon: ServerIcon },
    { id: 'sites', label: 'Web Assets', icon: Globe },
    { id: 'map', label: 'System Map', icon: Share2 },
    { id: 'errors', label: 'Live Errors', icon: Terminal },
    { id: 'incidents', label: 'Incidents', icon: AlertIcon },
  ];

  if (!isAuthenticated && !loading) {
     return <InteractiveAuth onAuth={() => setIsAuthenticated(true)} />;
  }  return (
    <div className="min-h-screen bg-[#050B18] text-[#E2E8F0] selection:bg-cyan-500/30 font-sans overflow-x-hidden">
      {/* Background Orbs */}
      <div className="fixed inset-0 pointer-events-none overflow-hidden">
         <motion.div 
           animate={{ scale: [1, 1.2, 1], x: [0, 50, 0] }}
           transition={{ duration: 20, repeat: Infinity }}
           className="absolute -top-[20%] -left-[10%] w-[60%] h-[60%] bg-cyan-500/5 blur-[150px] rounded-full" 
         />
         <motion.div 
           animate={{ scale: [1, 1.3, 1], x: [0, -40, 0] }}
           transition={{ duration: 25, repeat: Infinity }}
           className="absolute -bottom-[20%] -right-[10%] w-[70%] h-[70%] bg-indigo-500/5 blur-[150px] rounded-full" 
         />
      </div>

      <div className="relative z-10 max-w-[1600px] mx-auto p-4 md:p-8 space-y-8">
        
        {/* 1. TOP METRICS BAR */}
        <div className="grid grid-cols-12 items-center gap-8 pb-8 border-b border-white/5">
           <div className="col-span-12 lg:col-span-3 flex items-center gap-4">
              <div className="p-3 bg-cyan-500/10 rounded-2xl border border-cyan-500/20 shadow-[0_0_20px_rgba(6,182,212,0.1)]">
                 <Shield className="text-cyan-400" size={24} />
              </div>
              <div>
                 <h1 className="text-xl font-black uppercase tracking-tighter">AI AGENT MODULE</h1>
                 <div className="flex items-center gap-2">
                    <span className="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span className="text-[9px] font-black text-white/30 uppercase tracking-[0.2em]">Neural Connection Live</span>
                 </div>
              </div>
           </div>

           <div className="col-span-12 lg:col-span-6 flex items-center justify-center gap-8 md:gap-16">
              <CircularProgress value={healthScore} label="System Health" sublabel={healthScore > 90 ? 'OPTIMAL' : 'DEGRADED'} />
              <CircularProgress value={Math.min(100, (servers.filter(s => s.status === 'online').length / (servers.length || 1)) * 100)} label="Node Uptime" sublabel="Live" />
              <CircularProgress value={Math.max(0, 100 - (incidents.filter(i => i.status === 'OPEN').length * 5))} label="Security Level" sublabel="Stable" />
           </div>

           <div className="col-span-12 lg:col-span-3 flex items-center justify-end gap-6">
              <button 
                onClick={() => {
                  toggleMute();
                  play('click');
                }}
                className={`p-3 rounded-2xl border transition-all ${muted ? 'bg-rose-500/10 border-rose-500/30 text-rose-500' : 'bg-cyan-500/10 border-cyan-500/30 text-cyan-500'}`}
              >
                {muted ? <Mic size={18} /> : <Activity size={18} />}
              </button>
              <button 
                onClick={() => {
                   play('click');
                   setIsAuthenticated(false);
                }}
                className="group flex items-center gap-3 px-5 py-2.5 bg-white/[0.03] hover:bg-rose-500/10 border border-white/10 hover:border-rose-500/30 rounded-2xl transition-all"
              >
                 <LogOut size={14} className="text-white/40 group-hover:text-rose-500 transition-colors" />
                 <span className="text-[10px] font-black uppercase tracking-widest text-white/40 group-hover:text-rose-500 transition-colors">Terminate Link</span>
              </button>
           </div>
        </div>

        {/* 2. MAIN MODULAR GRID */}
        <div className="grid grid-cols-12 gap-8">
           
           {/* Left Sidebar: Navigation & Monitoring */}
           <div className="col-span-12 lg:col-span-3 space-y-8 h-full flex flex-col">
              <GlassPanel title="ACTIVE MONITORING" icon={Activity}>
                 <div className="space-y-6">
                    <div className="space-y-3">
                       <div className="flex justify-between items-center text-[9px] font-black text-white/30 uppercase tracking-widest">
                          <span>Active Assets</span>
                          <span className="text-cyan-400">{monitoredSites.length}</span>
                       </div>
                       <div className="h-1.5 bg-white/5 rounded-full overflow-hidden">
                          <motion.div initial={{ width: 0 }} animate={{ width: `${Math.min(100, (monitoredSites.filter(s => s.status !== 'offline').length/(monitoredSites.length||1))*100)}%` }} className="h-full bg-cyan-500 shadow-[0_0_10px_#06b6d4]"></motion.div>
                       </div>
                    </div>
                    <div className="space-y-3">
                       <div className="flex justify-between items-center text-[9px] font-black text-white/30 uppercase tracking-widest">
                          <span>Open Incidents</span>
                          <span className="text-rose-500">{incidents.filter(i => i.status === 'OPEN').length}</span>
                       </div>
                       <div className="h-1.5 bg-white/5 rounded-full overflow-hidden">
                          <motion.div initial={{ width: 0 }} animate={{ width: `${Math.min(100, incidents.filter(i => i.status === 'OPEN').length * 10)}%` }} className="h-full bg-rose-500 shadow-[0_0_10px_#f43f5e]"></motion.div>
                       </div>
                    </div>
                 </div>
                 <div className="mt-8 space-y-2">
                    {tabs.map(tab => (
                      <button 
                        key={tab.id}
                        onClick={() => {
                          setActiveTab(tab.id as any);
                          play('click');
                        }}
                        className={`w-full flex items-center justify-between p-4 rounded-2xl border transition-all ${activeTab === tab.id ? 'bg-cyan-500/10 border-cyan-500/30 text-cyan-400 shadow-[0_0_20px_rgba(6,182,212,0.1)]' : 'bg-transparent border-white/[0.03] text-white/30 hover:bg-white/[0.01] hover:text-white/60'}`}
                      >
                         <div className="flex items-center gap-4">
                            <tab.icon size={16} />
                            <span className="text-[10px] font-black uppercase tracking-[0.2em]">{tab.label}</span>
                         </div>
                         {activeTab === tab.id && <div className="w-1.5 h-1.5 rounded-full bg-cyan-400 shadow-[0_0_10px_#06b6d4]"></div>}
                      </button>
                    ))}
                 </div>
              </GlassPanel>

              <GlassPanel title="AI NEURO-CHAT" icon={Mic} className="flex-1 min-h-[400px]">
                 <div className="flex flex-col h-full justify-between gap-4">
                    <div className="flex-1 overflow-y-auto space-y-4 pr-2 custom-scrollbar">
                       <div className="p-4 bg-white/[0.03] border border-white/5 rounded-[20px] rounded-tl-none max-w-[90%]">
                          <p className="text-[11px] text-white/50 leading-relaxed font-medium italic">"Neural protocols active. Query authorized for infrastructure analysis."</p>
                       </div>
                       {aiAnalysis && (
                         <div className="p-4 bg-cyan-500/5 border border-cyan-500/20 rounded-[20px] rounded-tr-none ml-auto max-w-[90%] md:max-w-full">
                            <p className="text-[11px] text-cyan-400 leading-relaxed font-black uppercase tracking-tight">{aiAnalysis.summary}</p>
                         </div>
                       )}
                    </div>
                    <div className="relative mt-4">
                       <input 
                         className="w-full bg-black/40 border border-white/10 rounded-2xl px-5 py-3.5 text-[10px] focus:border-cyan-500/50 focus:outline-none placeholder:text-white/10 font-black tracking-widest transition-all" 
                         placeholder="Command AI Intelligence..."
                       />
                       <button className="absolute right-3 top-1/2 -translate-y-1/2 p-2 hover:text-cyan-400 transition-colors bg-white/5 rounded-xl border border-white/5">
                          <Mic size={14} />
                       </button>
                    </div>
                 </div>
              </GlassPanel>
           </div>

           {/* Main Content Area: HUD Centerpiece & Diagnostic Data */}
           <div className="col-span-12 lg:col-span-9 space-y-8">
                           {/* Top Section: AI Centerpiece HUD */}
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                 <div className="relative aspect-video bg-white/[0.01] border border-white/5 rounded-[40px] overflow-hidden flex items-center justify-center p-8 group">
                    <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(6,182,212,0.1)_0%,transparent_60%)] opacity-50"></div>
                    
                    <div className="relative w-64 h-64 flex items-center justify-center">
                       <Lottie 
                          animationData={{
                             // Futuristic HUD animation (abstract circles/waves)
                             v: "5.7.4", fr: 30, ip: 0, op: 60, w: 500, h: 500, nm: "AI_CORE", ddd: 0, 
                             assets: [], 
                             layers: [{
                                ddd:0, ind:1, ty:4, nm: "Pulse", sr:1, st:0, bm:0, 
                                shapes: [{
                                   ty: "gr", nm: "Circle", it: [{
                                      d:1, ty: "el", s:{a:0, k:[200, 200]}, p:{a:0, k:[0, 0]}, nm: "Path"
                                   }, {
                                      ty: "st", c:{a:0, k:[0.05, 0.65, 0.9, 1]}, o:{a:0, k:100}, w:{a:1, k:[{t:0, s:[2]}, {t:30, s:[10]}, {t:60, s:[2]}]}, nm: "Stroke"
                                   }]
                                }]
                             }]
                          }} 
                          className="absolute inset-0 opacity-40 scale-150"
                          loop 
                       />
                       <div className="text-center z-20">
                          <h2 className="text-6xl font-black tracking-tighter text-white drop-shadow-[0_0_30px_rgba(6,182,212,0.8)] uppercase">AI</h2>
                          <div className="flex items-center gap-2 mt-2">
                             <div className="w-1 h-1 rounded-full bg-cyan-400 animate-ping"></div>
                             <p className="text-[10px] font-black text-cyan-400 uppercase tracking-[.6em]">Neural Hub</p>
                          </div>
                       </div>
                    </div>

                    <div className="absolute bottom-10 left-1/2 -translate-x-1/2 w-[90%] flex gap-3 p-2.5 bg-black/60 border border-white/10 rounded-2xl backdrop-blur-xl shadow-2xl">
                       <input 
                          className="flex-1 bg-transparent px-6 py-2 text-[10px] font-black uppercase tracking-widest focus:outline-none placeholder:text-white/10" 
                          placeholder="Execute Neural Query..."
                       />
                       <button onClick={() => play('scan')} className="px-8 py-2 bg-gradient-to-r from-cyan-600 to-indigo-600 rounded-xl text-[9px] font-black uppercase tracking-widest hover:shadow-[0_0_20px_rgba(6,182,212,0.3)] transition-all">
                          Process
                       </button>
                    </div>
                 </div>

                 <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <GlassPanel title="ACTIVE SEQUENCES" icon={Layout}>
                       <div className="space-y-4 h-full flex flex-col justify-center">
                          {[1, 2, 3].map(i => (
                            <div key={`seq-${i}`} className="flex items-center gap-3">
                               <div className="w-5 h-5 rounded-lg border border-white/10 flex items-center justify-center bg-white/[0.02]">
                                  <CheckCircle size={10} className="text-cyan-500" />
                               </div>
                               <span className="text-[9px] text-white/30 font-black uppercase tracking-[0.2em]">Node_{i}_Integrity_OK</span>
                            </div>
                          ))}
                       </div>
                    </GlassPanel>
                    <GlassPanel title="THREAT VECTOR" icon={Cpu}>
                       <div className="flex flex-col items-center justify-center h-full py-2">
                          <div className="w-20 h-20 bg-white/[0.02] rounded-[24px] border border-white/5 flex items-center justify-center relative group">
                             <motion.div 
                                animate={{ rotate: 360 }}
                                transition={{ duration: 6, repeat: Infinity, ease: 'linear' }}
                                className="absolute inset-0 border-2 border-transparent border-t-cyan-500 rounded-[24px] opacity-40"
                             />
                             <ShieldAlert className="text-cyan-400 group-hover:scale-110 transition-transform" size={24} />
                          </div>
                          <span className="text-[9px] font-black text-white/30 uppercase tracking-[.4em] mt-4">Neutral_Scan</span>
                       </div>
                    </GlassPanel>
                 </div>
              </div>

              {/* Bottom Section: Wide Diagnostics View */}
              <GlassPanel title={`DETAILED SYSTEM DIAGNOSTICS [${activeTab.toUpperCase()}]`} icon={Search} className="min-h-[500px]">
                 <AnimatePresence mode="wait">
                    <motion.div
                       key={activeTab}
                       initial={{ opacity: 0, x: -20 }}
                       animate={{ opacity: 1, x: 0 }}
                       exit={{ opacity: 0, x: 20 }}
                       transition={{ duration: 0.3, ease: "circOut" }}
                       className="w-full h-full"
                    >
                       {activeTab === 'overview' && <FleetOverview websites={monitoredSites} servers={servers} securityScore={healthScore} />}
                       {activeTab === 'infra' && <ServerGrid />}
                       {activeTab === 'sites' && (
                         <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                            {monitoredSites.map((site, i) => (
                              <SiteCard 
                                key={site.id || `site-${i}`} 
                                target={site.target} 
                                vps={site.vps} 
                                onClick={() => {
                                  setSelectedSite(site);
                                  play('click');
                                }} 
                              />
                            ))}
                         </div>
                       )}
                       {activeTab === 'incidents' && (
                         <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                            {incidents.slice(0, 6).map((inc, i) => (
                              <div key={inc.id || `inc-${i}`} className="p-6 bg-white/[0.02] border border-white/5 rounded-[24px] transition-all hover:bg-white/[0.04] group relative overflow-hidden">
                                 <div className="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                    <AlertTriangle size={40} className={inc.severity === 'CRITICAL' ? 'text-rose-500' : 'text-amber-500'} />
                                 </div>
                                 <div className="flex justify-between items-center mb-4 relative z-10">
                                    <span className={`px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-widest border ${inc.severity === 'CRITICAL' ? 'bg-rose-500/10 border-rose-500/20 text-rose-400' : 'bg-amber-500/10 border-amber-500/20 text-amber-400'}`}>
                                       {inc.severity}
                                    </span>
                                    <span className="text-[9px] font-black text-white/20 uppercase tracking-tighter">{new Date(inc.timestamp).toLocaleString()}</span>
                                 </div>
                                 <h4 className="text-sm font-black text-white uppercase tracking-tight mb-2 relative z-10">{inc.target}</h4>
                                 <p className="text-[11px] text-white/40 leading-relaxed font-medium relative z-10">{inc.description}</p>
                              </div>
                            ))}
                         </div>
                       )}
                       {activeTab === 'errors' && <ErrorStream />}
                       {activeTab === 'map' && <InfrastructureTopology />}
                    </motion.div>
                 </AnimatePresence>
              </GlassPanel>
           </div>
        </div>

        {/* 3. BOTTOM PROGRESS BAR */}
        <div className="pt-8 space-y-4">
           <div className="flex justify-between items-end">
              <div className="flex flex-col">
                 <span className="text-4xl font-black tracking-tighter text-cyan-500 drop-shadow-[0_0_15px_rgba(6,182,212,0.3)]">79%</span>
                 <span className="text-[9px] font-black text-white/20 uppercase tracking-[0.4em]">NEURAL SYNAPTIC LOAD</span>
              </div>
              <div className="flex gap-1">
                 {[1, 2, 3, 4, 5].map(i => (
                   <div key={`idx-${i}`} className="w-8 h-8 rounded-lg border border-white/10 bg-white/[0.03] flex items-center justify-center overflow-hidden group hover:border-cyan-500/30 transition-all cursor-pointer">
                      <ImageIcon className="text-white/20 group-hover:text-cyan-400" size={14} />
                   </div>
                 ))}
              </div>
           </div>
           <div className="h-4 bg-white/[0.03] border border-white/5 rounded-full p-1 overflow-hidden">
              <motion.div 
                 initial={{ width: 0 }}
                 animate={{ width: '79%' }}
                 className="h-full bg-gradient-to-r from-cyan-600 to-indigo-600 rounded-full relative"
              >
                 <div className="absolute inset-0 bg-[linear-gradient(45deg,rgba(255,255,255,0.1)_25%,transparent_25%,transparent_50%,rgba(255,255,255,0.1)_50%,rgba(255,255,255,0.1)_75%,transparent_75%,transparent)] bg-[length:24px_24px] animate-[slide_1s_linear_infinite]"></div>
              </motion.div>
           </div>
        </div>

        <footer className="pt-12 flex justify-between items-center opacity-20">
           <span className="text-[8px] font-black uppercase tracking-[.4em]">Integrated Intelligence System © 2026</span>
           <div className="flex gap-6">
              <span className="text-[8px] font-black uppercase tracking-[.4em] cursor-pointer hover:text-cyan-400">Manual</span>
              <span className="text-[8px] font-black uppercase tracking-[.4em] cursor-pointer hover:text-cyan-400">API</span>
           </div>
        </footer>

      </div>

      <ChatWidget activeIncident={incidents.length > 0 ? incidents[0] : undefined} />
      
      <CommandPalette 
        isOpen={isCommandPaletteOpen} 
        onClose={() => setIsCommandPaletteOpen(false)}
        onAction={(action, target) => {
          if (action.startsWith('go-')) {
            setActiveTab(action.split('-')[1] as any);
          } else {
            console.log(`Executing palette command: ${action} on ${target}`);
          }
        }}
      />
      
      <style jsx global>{`
        @keyframes slide {
          from { background-position: 0 0; }
          to { background-position: 24px 0; }
        }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      `}</style>
    </div>
  );
}
